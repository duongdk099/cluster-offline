{
  "name": "NotesAides Lean Codespace",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu", 
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers-contrib/features/bun:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "oven.bun-vscode",
        "rust-lang.rust-analyzer",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"
      ]
    }
  },
  "onCreateCommand": "pnpm install && cd api && bun install && (curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y) && . $HOME/.cargo/env && rustup target add wasm32-unknown-unknown",
  "postStartCommand": "docker compose up -d db",
  "forwardPorts": [3000, 3001, 5432],
  "portsAttributes": {
    "3001": { "visibility": "public" },
    "3000": { "onAutoForward": "openPreview" }
  }
}
