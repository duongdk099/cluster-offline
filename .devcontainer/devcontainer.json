{
  "name": "NotesAides Workspace",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts",
      "pnpm": "latest"
    },
    "ghcr.io/devcontainers-contrib/features/bun:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "latest",
      "profile": "default"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "enableNonRootDocker": "true",
      "moby": "true"
    }
  },
  "customizations": {
    "codespaces": { "idleTimeout": "30m" },
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "rust-lang.rust-analyzer",
        "oven.bun-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "forwardPorts": [3000, 3001, 5433],
  "portsAttributes": {
    "3000": {
      "label": "Next.js Frontend",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "3001": {
      "label": "Hono API",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "5433": {
      "label": "PostgreSQL Database",
      "onAutoForward": "silent"
    }
  },
  "postCreateCommand": "pnpm install && cd api && bun install",
  "postStartCommand": "bash -c 'docker compose up -d db && sleep 4 && cd api && bun run db:push && cd .. && echo \"CORS_ORIGIN=https://${CODESPACE_NAME}-3000.app.github.dev\" > api/.env && echo \"TRUST_PROXY_HEADERS=true\" >> api/.env && echo \"NEXT_PUBLIC_API_URL=https://${CODESPACE_NAME}-3001.app.github.dev\" > front/.env.local && echo \"NEXT_PUBLIC_WS_URL=wss://${CODESPACE_NAME}-3001.app.github.dev/ws\" >> front/.env.local'"
}