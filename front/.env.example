#############################
# Frontend environment template
#############################

# 1) Local development (recommended)
# - Copy this file to front/.env.local for local dev
NUXT_PUBLIC_API_URL=http://localhost:3001
NUXT_PUBLIC_WS_URL=ws://localhost:3001/ws
NODE_ENV=development

# 2) GitHub Codespaces
# When running in Codespaces, set these to the forwarded domains
# Example (replace <codespace> with your codespace hostname):
# NUXT_PUBLIC_API_URL=https://<codespace>-3001.app.github.dev
# NUXT_PUBLIC_WS_URL=wss://<codespace>-3001.app.github.dev/ws

# 3) Production / VPS
# Use your canonical public endpoints in production. Do NOT use wildcards.
# Example:
# NUXT_PUBLIC_API_URL=https://api.your-domain.com
# NUXT_PUBLIC_WS_URL=wss://api.your-domain.com/ws
# NODE_ENV=production

# Notes:
# - The backend may also require matching settings in api/.env (CORS_ORIGIN, API_URL, TRUST_PROXY_HEADERS).
# - After editing env files, restart both frontend and backend to apply changes.
